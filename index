        ${s.status === 'active' ? `
          <div class="signal-progress">
            <span>SL</span>
            <div class="progress-track"><div class="progress-fill ${progressPct > 50 ? 'bull' : 'bear'}" style="width:${progressPct}%"></div></div>
            <span>TP</span>
            <span class="live-pnl" style="color: ${pnlR >= 0 ? 'var(--bull)' : 'var(--bear)'}; font-weight: 600;">${pnlR >= 0 ? '+' : ''}${pnlR.toFixed(2)}R</span>
          </div>
        ` : ''}
        <div class="signal-meta">
          <span class="reason">${s.reason}</span>
          <a href="https://www.tradingview.com/chart/?symbol=BINANCE:${s.pair}.P" target="_blank" rel="noopener">View chart ↗</a>
          <span>${ageTxt}</span>
        </div>
      </div>
    `;
  }).join('');
}

function setScanProgress(done, total, label) {
  const pct = total > 0 ? (done / total) * 100 : 0;
  document.getElementById('scanProgressFill').style.width = pct + '%';
  document.getElementById('scanProgressCount').textContent = `${done} / ${total}`;
  document.getElementById('scanProgressLabel').textContent = label;
  document.getElementById('scanProgressContainer').classList.toggle('done', done >= total && total > 0);
}

// ============================================================
// PERFORMANCE
// ============================================================
function groupStats(signals, keyFn) {
  const groups = {};
  signals.forEach(s => {
    if (s.status !== 'tp' && s.status !== 'sl') return;
    const k = keyFn(s);
    if (!groups[k]) groups[k] = { wins: 0, losses: 0, totalR: 0 };
    groups[k][s.status === 'tp' ? 'wins' : 'losses']++;
    if (s.pnlR != null) groups[k].totalR += s.pnlR;
  });
  return Object.entries(groups).map(([k, v]) => {
    const total = v.wins + v.losses;
    return { key: k, wins: v.wins, losses: v.losses, total, wr: total > 0 ? (v.wins / total * 100) : 0, totalR: v.totalR, avgR: total > 0 ? v.totalR / total : 0 };
  }).sort((a, b) => b.total - a.total);
}
function classifyWR(wr, count) {
  if (count < 5) return 'muted';
  if (wr >= 55) return 'up';
  if (wr <= 35) return 'down';
  return 'warn';
}
function renderPerformance() {
  // Only count v5 signals for new stats; old v4 signals show in "all-time" but not v5
  const v5Signals = state.signals.filter(s => s.version === 'v5');
  const v5Closed = v5Signals.filter(s => s.status === 'tp' || s.status === 'sl');
  const closed = v5Closed; // current strategy only
  const c = document.getElementById('perfContent');
  if (closed.length < 5) {
    c.innerHTML = `<div class="perf-empty"><h3>${closed.length} of 5 v5 trades complete</h3><p>v5 introduced a trend filter + Volume Profile strategy. Stats reset for a clean evaluation. Performance breakdowns appear after 5 closed trades — typically 1-3 days of running.</p></div>`;
    return;
  }
  const wins = closed.filter(s => s.status === 'tp').length;
  const losses = closed.length - wins;
  const wr = wins / closed.length * 100;
  const totalR = closed.reduce((a, s) => a + (s.pnlR || 0), 0);
  const avgR = totalR / closed.length;
  const grossWin = closed.filter(s => s.pnlR > 0).reduce((a, s) => a + s.pnlR, 0);
  const grossLoss = Math.abs(closed.filter(s => s.pnlR < 0).reduce((a, s) => a + s.pnlR, 0));
  const pf = grossLoss > 0 ? grossWin / grossLoss : grossWin > 0 ? Infinity : 0;
  const configStats = groupStats(closed, s => configKey(s.pair, s.strategy, s.tf));
  const autoDisable = configStats.filter(c => c.total >= 5 && c.wr < 40);
  const pairStats = groupStats(closed, s => s.pair);
  const stratStats = groupStats(closed, s => s.strategy);
  const tfStats = groupStats(closed, s => s.tf);
  const hourStats = {};
  closed.forEach(s => { const h = new Date(s.createdAt).getHours(); if (!hourStats[h]) hourStats[h] = { wins: 0, losses: 0 }; hourStats[h][s.status === 'tp' ? 'wins' : 'losses']++; });
  let banner = '';
  if (autoDisable.length > 0) banner = `<div class="filter-banner"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg><div><b>${autoDisable.length} configuration(s)</b> are losing on 5+ trades. Consider disabling them below.</div></div>`;
  c.innerHTML = `
    ${banner}
    <div class="perf-hero">
      <div class="perf-hero-cell"><div class="perf-hero-label">v5 win rate</div><div class="perf-hero-value ${wr >= 50 ? 'up' : 'down'}">${wr.toFixed(1)}%</div><div class="perf-hero-note">${closed.length} closed trades</div></div>
      <div class="perf-hero-cell"><div class="perf-hero-label">Profit factor</div><div class="perf-hero-value ${pf >= 1.3 ? 'up' : pf >= 1 ? 'warn' : 'down'}">${isFinite(pf) ? pf.toFixed(2) : '∞'}</div><div class="perf-hero-note">${pf >= 1.3 ? 'Healthy' : pf >= 1 ? 'Marginal' : 'Negative'}</div></div>
      <div class="perf-hero-cell"><div class="perf-hero-label">Total return</div><div class="perf-hero-value ${totalR >= 0 ? 'up' : 'down'}">${totalR >= 0 ? '+' : ''}${totalR.toFixed(1)}R</div><div class="perf-hero-note">Sum PnL in R</div></div>
      <div class="perf-hero-cell"><div class="perf-hero-label">Avg per trade</div><div class="perf-hero-value ${avgR >= 0 ? 'up' : 'down'}">${avgR >= 0 ? '+' : ''}${avgR.toFixed(2)}R</div><div class="perf-hero-note">${wins}W / ${losses}L</div></div>
    </div>
    <div class="perf-section">
      <div class="perf-section-title">By configuration <span class="help">disable underperformers</span></div>
      <table class="perf-table"><thead><tr><th>Config</th><th>Trades</th><th>Win rate</th><th>Total R</th><th>Avg R</th><th></th></tr></thead><tbody>${configStats.map(s => {
        const [pair, strat, tf] = s.key.split(':');
        const disabled = state.disabledConfigs.has(s.key);
        const wrClass = classifyWR(s.wr, s.total);
        return `<tr class="${disabled ? 'disabled' : ''}"><td><b>${pair.replace('USDT','')}</b> · ${strat} · ${tf}</td><td>${s.total} <span class="muted">(${s.wins}W/${s.losses}L)</span></td><td>${s.wr.toFixed(0)}% <span class="wr-bar"><span class="wr-bar-fill ${wrClass}" style="width:${s.wr}%"></span></span></td><td class="${s.totalR >= 0 ? 'bull-cell' : 'bear-cell'}">${s.totalR >= 0 ? '+' : ''}${s.totalR.toFixed(2)}R</td><td class="${s.avgR >= 0 ? 'bull-cell' : 'bear-cell'}">${s.avgR >= 0 ? '+' : ''}${s.avgR.toFixed(2)}R</td><td><button class="disable-btn ${disabled ? 'disabled' : ''}" data-config="${s.key}">${disabled ? 'Disabled' : 'Disable'}</button></td></tr>`;
      }).join('')}</tbody></table>
    </div>
    <div class="perf-section">
      <div class="perf-section-title">By pair</div>
      <table class="perf-table"><thead><tr><th>Pair</th><th>Trades</th><th>Win rate</th><th>Total R</th></tr></thead><tbody>${pairStats.map(s => { const wrClass = classifyWR(s.wr, s.total); return `<tr><td><b>${s.key.replace('USDT','')}</b></td><td>${s.total}</td><td>${s.wr.toFixed(0)}% <span class="wr-bar"><span class="wr-bar-fill ${wrClass}" style="width:${s.wr}%"></span></span></td><td class="${s.totalR >= 0 ? 'bull-cell' : 'bear-cell'}">${s.totalR >= 0 ? '+' : ''}${s.totalR.toFixed(2)}R</td></tr>`; }).join('')}</tbody></table>
    </div>
    <div class="perf-section">
      <div class="perf-section-title">By strategy</div>
      <table class="perf-table"><thead><tr><th>Strategy</th><th>Trades</th><th>Win rate</th><th>Total R</th></tr></thead><tbody>${stratStats.map(s => { const wrClass = classifyWR(s.wr, s.total); return `<tr><td><b>${s.key}</b></td><td>${s.total}</td><td>${s.wr.toFixed(0)}% <span class="wr-bar"><span class="wr-bar-fill ${wrClass}" style="width:${s.wr}%"></span></span></td><td class="${s.totalR >= 0 ? 'bull-cell' : 'bear-cell'}">${s.totalR >= 0 ? '+' : ''}${s.totalR.toFixed(2)}R</td></tr>`; }).join('')}</tbody></table>
    </div>
    <div class="perf-section">
      <div class="perf-section-title">By timeframe</div>
      <table class="perf-table"><thead><tr><th>TF</th><th>Trades</th><th>Win rate</th><th>Total R</th></tr></thead><tbody>${tfStats.map(s => { const wrClass = classifyWR(s.wr, s.total); return `<tr><td><b>${s.key}</b></td><td>${s.total}</td><td>${s.wr.toFixed(0)}% <span class="wr-bar"><span class="wr-bar-fill ${wrClass}" style="width:${s.wr}%"></span></span></td><td class="${s.totalR >= 0 ? 'bull-cell' : 'bear-cell'}">${s.totalR >= 0 ? '+' : ''}${s.totalR.toFixed(2)}R</td></tr>`; }).join('')}</tbody></table>
    </div>
  `;
  c.querySelectorAll('.disable-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.config;
      if (state.disabledConfigs.has(key)) state.disabledConfigs.delete(key);
      else state.disabledConfigs.add(key);
      persistFilters(); renderPerformance();
    });
  });
}

// Export/Import
document.getElementById('exportBtn').addEventListener('click', () => {
  const data = { signals: state.signals, disabledConfigs: [...state.disabledConfigs], exportedAt: new Date().toISOString(), version: 'v5' };
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = `sawaiz-signals-${new Date().toISOString().split('T')[0]}.json`;
  a.click(); URL.revokeObjectURL(url);
});
document.getElementById('importBtn').addEventListener('click', () => document.getElementById('importFile').click());
document.getElementById('importFile').addEventListener('change', (e) => {
  const file = e.target.files[0]; if (!file) return;
  const reader = new FileReader();
  reader.onload = (ev) => {
    try {
      const data = JSON.parse(ev.target.result);
      if (data.signals && Array.isArray(data.signals)) {
        if (confirm(`Import ${data.signals.length} signals? This will REPLACE current history.`)) {
          state.signals = data.signals;
          if (data.disabledConfigs) state.disabledConfigs = new Set(data.disabledConfigs);
          persist(); persistFilters();
          renderSignals(); renderPerformance();
          alert('Imported.');
        }
      } else alert('Invalid file.');
    } catch (err) { alert('Failed to parse JSON.'); }
  };
  reader.readAsText(file);
});

// ============================================================
// MAIN SCAN
// ============================================================
async function fullScan() {
  document.getElementById('liveDot').className = 'live-dot connecting';
  document.getElementById('liveText').textContent = 'Scanning';
  setScanProgress(0, PAIRS.length, 'Loading');

  await fetchBtcTicker();

  // BTC verdict timeframes
  const btcTfResults = await Promise.all(TIMEFRAMES.map(async tf => {
    try {
      const candles = await fetchKlines('BTCUSDT', tf.bin, 120);
      return { ...tf, analysis: analyze(candles) };
    } catch (e) { return { ...tf, analysis: null }; }
  }));

  // Compute trend for each pair (1h EMA50)
  for (const pair of PAIRS) {
    try {
      const c1h = await fetchKlines(pair, '1h', 120);
      state.pairTrends[pair] = computePairTrend(c1h);
    } catch (e) { state.pairTrends[pair] = { direction: 'flat', strength: 0 }; }
  }

  // Multi-pair signal scan
  state.watching = [];
  let done = 0;
  for (const pair of PAIRS) {
    const htfTrend = state.pairTrends[pair] || { direction: 'flat', strength: 0 };
    for (const tf of SIGNAL_TFS) {
      try {
        const candles = await fetchKlines(pair, tf, 120);
        if (candles.length < 30) continue;
        const a = analyze(candles);
        // Backstop active signals against latest candle
        for (const sig of state.signals) {
          if (sig.pair !== pair || sig.tf !== tf || sig.status !== 'active') continue;
          const lc = candles[candles.length - 1];
          if (sig.side === 'long') {
            if (lc.l <= sig.stop) closeSignal(sig, 'sl', sig.stop);
            else if (lc.h >= sig.target) closeSignal(sig, 'tp', sig.target);
          } else {
            if (lc.h >= sig.stop) closeSignal(sig, 'sl', sig.stop);
            else if (lc.l <= sig.target) closeSignal(sig, 'tp', sig.target);
          }
        }
        // New signals (trend filter applied inside generateSignals)
        generateSignals(pair, tf, a, htfTrend).forEach(s => addSignal(pair, tf, s));
        state.watching.push(...generateWatching(pair, tf, a, htfTrend));
      } catch (e) {}
    }
    done++;
    setScanProgress(done, PAIRS.length, 'Scanning');
  }

  const deriv = await fetchDerivatives();
  renderTimeframes(btcTfResults);
  renderDerivatives(deriv);
  renderVerdict(btcTfResults, deriv);
  renderWatching();
  renderSignals();
  persist();
  state.lastScanAt = Date.now();
  document.getElementById('lastRefresh').textContent = new Date().toLocaleTimeString();
  document.getElementById('liveDot').className = 'live-dot';
  document.getElementById('liveText').textContent = 'Live';
  setScanProgress(PAIRS.length, PAIRS.length, 'Complete');
}

document.getElementById('filter-active').addEventListener('change', renderSignals);
document.getElementById('filter-closed').addEventListener('change', renderSignals);
document.getElementById('tfFilter').addEventListener('change', renderSignals);
document.getElementById('pairFilter').addEventListener('change', renderSignals);
document.getElementById('clearHistory').addEventListener('click', () => {
  if (confirm('Clear all signal history? This cannot be undone.')) { state.signals = []; persist(); renderSignals(); }
});

connectWS();
fullScan();
setInterval(fullScan, 60000);
setInterval(() => { renderSignals(); }, 5000);
