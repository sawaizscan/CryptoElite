// ANALYSIS (for verdict — unchanged BTC logic)
// ============================================================
function analyze(candles) {
  const closes = candles.map(c => c.c);
  const vols = candles.map(c => c.v);
  const c = candles[candles.length - 1];
  const ema20 = ema(closes, 20);
  const ema50 = ema(closes, 50);
  const rsiV = rsi(closes, 14);
  const recent = candles.slice(-21, -1);
  const hi20 = Math.max(...recent.map(x => x.h));
  const lo20 = Math.min(...recent.map(x => x.l));
  const avgVol = sma(vols.slice(0, -1), 20);
  const volMult = avgVol ? c.v / avgVol : 1;
  let trend=0, momentum=0, breakout=0, volume=0;
  if (ema20 && ema50) {
    if (c.c > ema20 && ema20 > ema50) trend=2;
    else if (c.c < ema20 && ema20 < ema50) trend=-2;
    else if (c.c > ema20) trend=1;
    else if (c.c < ema20) trend=-1;
  }
  if (rsiV != null) {
    if (rsiV > 70) momentum=2;
    else if (rsiV > 55) momentum=1;
    else if (rsiV < 30) momentum=-2;
    else if (rsiV < 45) momentum=-1;
  }
  if (c.c > hi20) breakout=2;
  else if (c.c < lo20) breakout=-2;
  else if (c.c > hi20 * 0.995) breakout=1;
  else if (c.c < lo20 * 1.005) breakout=-1;
  if (volMult > 1.8) volume = (trend+momentum+breakout) >= 0 ? 2 : -2;
  else if (volMult > 1.3) volume = (trend+momentum+breakout) >= 0 ? 1 : -1;
  const total = trend + momentum + breakout + volume;
  let verdict = 'neutral', cls = 'neutral';
  if (total >= 4) { verdict='bullish'; cls='bull'; }
  else if (total >= 2) { verdict='lean bull'; cls='bull'; }
  else if (total <= -4) { verdict='bearish'; cls='bear'; }
  else if (total <= -2) { verdict='lean bear'; cls='bear'; }
  return { verdict, cls, score: total, rsi: rsiV, price: c.c, hi20, lo20, atr: atr(candles, 14), volMult, candles };
}

