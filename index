function renderVerdict(results, deriv) {
  const weights = Object.fromEntries(TIMEFRAMES.map(t => [t.bin, t.weight]));
  let totalScore = 0, totalW = 0, bullCount = 0, bearCount = 0, neutCount = 0;
  results.forEach(r => {
    if (!r.analysis) return;
    const w = weights[r.bin] || 1;
    totalScore += r.analysis.score * w; totalW += w * 8;
    if (r.analysis.cls === 'bull') bullCount++;
    else if (r.analysis.cls === 'bear') bearCount++;
    else neutCount++;
  });
  const norm = totalW > 0 ? (totalScore / totalW) * 100 : 0;
  let adj = 0;
  if (deriv.funding != null) { if (deriv.funding > 0.05) adj -= 8; else if (deriv.funding < -0.05) adj += 8; }
  if (deriv.ls) { if (deriv.ls.ratio > 2.5) adj -= 6; else if (deriv.ls.ratio < 0.6) adj += 6; }
  const final = Math.max(-100, Math.min(100, norm + adj));
  let word = 'neutral', cls = 'neutral';
  if (final > 35) { word = 'bullish'; cls = 'bull'; }
  else if (final > 15) { word = 'lean bull'; cls = 'bull'; }
  else if (final < -35) { word = 'bearish'; cls = 'bear'; }
