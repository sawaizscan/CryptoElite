<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Sawaiz Signals</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800&family=Geist+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style>
:root {
  --bg-0: #0a0a0c; --bg-1: #111114; --bg-2: #16161a; --bg-3: #1c1c21; --bg-4: #25252c;
  --line: #25252c; --line-2: #34343e;
  --ink-0: #ffffff; --ink-1: #ededf0; --ink-2: #8a8a96; --ink-3: #525260; --ink-4: #34343e;
  --bull: #00d18d; --bull-bg: rgba(0,209,141,0.10); --bull-glow: rgba(0,209,141,0.35);
  --bear: #ff5470; --bear-bg: rgba(255,84,112,0.10); --bear-glow: rgba(255,84,112,0.35);
  --warn: #ffaa3a; --warn-bg: rgba(255,170,58,0.10);
  --accent: #7c5cff; --accent-bg: rgba(124,92,255,0.12);
  --sans: 'Geist', system-ui, sans-serif;
  --mono: 'Geist Mono', ui-monospace, monospace;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html { -webkit-font-smoothing: antialiased; }
body {
  background: var(--bg-0); color: var(--ink-1); font-family: var(--sans);
  font-size: 14px; line-height: 1.5; min-height: 100vh; letter-spacing: -0.011em;
  background-image: radial-gradient(ellipse 800px 600px at 20% -10%, rgba(124,92,255,0.06), transparent 70%), radial-gradient(ellipse 600px 400px at 90% 110%, rgba(0,209,141,0.04), transparent 70%);
}
button { font-family: inherit; cursor: pointer; }
a { color: inherit; text-decoration: none; }

.topbar { display: flex; align-items: center; justify-content: space-between; padding: 16px 24px; border-bottom: 1px solid var(--line); background: rgba(10,10,12,0.85); backdrop-filter: blur(20px); position: sticky; top: 0; z-index: 100; gap: 20px; flex-wrap: wrap; }
.brand { display: flex; align-items: center; gap: 12px; }
.brand-logo { width: 36px; height: 36px; flex-shrink: 0; }
.brand-text { display: flex; flex-direction: column; line-height: 1; }
.brand-name { font-weight: 600; font-size: 16px; letter-spacing: -0.03em; background: linear-gradient(180deg, #fff, #b8b8c4); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
.brand-tag { font-family: var(--mono); font-size: 10px; color: var(--ink-3); letter-spacing: 0.05em; margin-top: 3px; text-transform: uppercase; }
.live-price { display: flex; align-items: center; gap: 14px; flex: 1; justify-content: center; min-width: 0; }
.price-label { font-family: var(--mono); font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.1em; }
.price-big { font-family: var(--mono); font-size: 26px; font-weight: 600; letter-spacing: -0.03em; transition: color 0.15s; font-variant-numeric: tabular-nums; color: var(--ink-0); }
.price-big.up { color: var(--bull); }
.price-big.down { color: var(--bear); }
.delta-pill { font-family: var(--mono); font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 6px; font-variant-numeric: tabular-nums; }
.delta-pill.up { background: var(--bull-bg); color: var(--bull); }
.delta-pill.down { background: var(--bear-bg); color: var(--bear); }
.status-cluster { display: flex; align-items: center; gap: 8px; }
.status-pill { display: flex; align-items: center; gap: 7px; background: var(--bg-2); border: 1px solid var(--line); padding: 7px 12px; border-radius: 8px; font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 500; color: var(--ink-2); }
.live-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--bull); box-shadow: 0 0 8px var(--bull-glow); animation: pulse 1.6s ease-in-out infinite; }
.live-dot.off { background: var(--bear); box-shadow: 0 0 8px var(--bear-glow); animation: none; }
.live-dot.idle { background: var(--ink-3); box-shadow: none; animation: none; }
.live-dot.connecting { background: var(--warn); box-shadow: 0 0 8px rgba(255,170,58,0.5); animation: pulse 0.9s ease-in-out infinite; }
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

.tabs { display: flex; padding: 0 24px; background: var(--bg-1); border-bottom: 1px solid var(--line); gap: 4px; overflow-x: auto; }
.tab-btn { background: none; border: none; padding: 14px 18px; font-family: var(--mono); font-size: 11px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.12em; font-weight: 500; cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.15s; white-space: nowrap; }
.tab-btn:hover { color: var(--ink-1); }
.tab-btn.active { color: var(--ink-0); border-bottom-color: var(--accent); }
.tab-btn .badge { display: inline-block; background: var(--accent-bg); color: var(--accent); font-size: 9px; padding: 2px 6px; border-radius: 4px; margin-left: 6px; font-weight: 700; }

.market-strip { display: grid; grid-template-columns: repeat(5, 1fr); background: var(--bg-1); border-bottom: 1px solid var(--line); }
.market-cell { padding: 12px 20px; border-right: 1px solid var(--line); display: flex; flex-direction: column; gap: 3px; }
.market-cell:last-child { border-right: none; }
.market-label { font-family: var(--mono); font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 500; }
.market-value { font-family: var(--mono); font-size: 14px; font-weight: 600; font-variant-numeric: tabular-nums; color: var(--ink-1); }
.market-value.up { color: var(--bull); }
.market-value.down { color: var(--bear); }
.market-value.warn { color: var(--warn); }
@media (max-width: 900px) { .market-strip { grid-template-columns: repeat(2, 1fr); } .market-cell { border-right: none; border-bottom: 1px solid var(--line); } }

.scan-progress { padding: 6px 24px; background: var(--bg-1); border-bottom: 1px solid var(--line); display: flex; align-items: center; gap: 12px; font-family: var(--mono); font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.08em; }
.scan-progress-bar { flex: 1; height: 3px; background: var(--bg-3); border-radius: 2px; overflow: hidden; }
.scan-progress-fill { height: 100%; background: var(--accent); transition: width 0.3s; width: 0%; box-shadow: 0 0 8px rgba(124,92,255,0.5); }
.scan-progress.done .scan-progress-fill { background: var(--bull); box-shadow: 0 0 8px var(--bull-glow); }

.panel { display: none; }
.panel.active { display: block; }

/* KEY: signals get 65%, analysis 35% */
.main { display: grid; grid-template-columns: 35fr 65fr; gap: 0; min-height: calc(100vh - 160px); }
@media (max-width: 1200px) { .main { grid-template-columns: 1fr; } }
.col { border-right: 1px solid var(--line); display: flex; flex-direction: column; }
.col:last-child { border-right: none; }
.col-head { display: flex; justify-content: space-between; align-items: center; padding: 16px 24px; border-bottom: 1px solid var(--line); gap: 12px; flex-wrap: wrap; }
.col-head h2 { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ink-2); }
.col-head .meta { font-family: var(--mono); font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.08em; }
.col-head .meta b { color: var(--ink-1); font-weight: 500; }

.hero-verdict { padding: 32px 24px 28px; border-bottom: 1px solid var(--line); position: relative; overflow: hidden; }
.hero-verdict::before { content: ''; position: absolute; top: -80px; right: -80px; width: 280px; height: 280px; border-radius: 50%; background: var(--ink-3); opacity: 0.08; filter: blur(50px); pointer-events: none; transition: background 0.6s; }
.hero-verdict.bull::before { background: var(--bull); opacity: 0.18; }
.hero-verdict.bear::before { background: var(--bear); opacity: 0.18; }
.hero-verdict.neutral::before { background: var(--warn); opacity: 0.12; }
.hero-label { font-family: var(--mono); font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.15em; font-weight: 500; margin-bottom: 12px; position: relative; }
.hero-word { font-size: clamp(44px, 5.5vw, 64px); font-weight: 700; letter-spacing: -0.05em; line-height: 0.95; text-transform: lowercase; margin-bottom: 14px; position: relative; color: var(--ink-0); }
.hero-verdict.bull .hero-word { color: var(--bull); }
.hero-verdict.bear .hero-word { color: var(--bear); }
.hero-verdict.neutral .hero-word { color: var(--warn); }
.hero-meta { display: flex; gap: 18px; align-items: baseline; flex-wrap: wrap; position: relative; }
.hero-score { font-family: var(--mono); font-size: 22px; font-weight: 600; font-variant-numeric: tabular-nums; letter-spacing: -0.02em; color: var(--ink-0); }
.hero-conf { font-family: var(--mono); font-size: 11px; color: var(--ink-2); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 500; }
.hero-conf b { color: var(--ink-0); font-weight: 600; }

.tf-section { flex: 1; }
.tf-section-head { padding: 14px 24px 10px; }
.tf-section-head h3 { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ink-2); }
.tf-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--line); }
.tf-card { background: var(--bg-0); padding: 14px 18px; display: flex; flex-direction: column; gap: 8px; }
.tf-card-tf { font-family: var(--mono); font-size: 10px; font-weight: 500; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.1em; }
.tf-card-verdict { font-size: 16px; font-weight: 600; letter-spacing: -0.03em; text-transform: lowercase; }
.tf-card-verdict.bull { color: var(--bull); }
.tf-card-verdict.bear { color: var(--bear); }
.tf-card-verdict.neutral { color: var(--warn); }
.tf-card-meter { height: 3px; background: var(--bg-3); border-radius: 2px; position: relative; overflow: hidden; }
.tf-card-meter::before { content: ''; position: absolute; left: 50%; top: 0; width: 1px; height: 100%; background: var(--line-2); }
.tf-card-meter-fill { position: absolute; top: 0; height: 100%; transition: all 0.5s ease; }
.tf-card-meter-fill.bull { background: var(--bull); left: 50%; }
.tf-card-meter-fill.bear { background: var(--bear); right: 50%; }

.deriv-strip { display: grid; grid-template-columns: repeat(3, 1fr); background: var(--line); gap: 1px; border-top: 1px solid var(--line); }
.deriv-cell { background: var(--bg-0); padding: 14px 18px; }
.deriv-label { font-family: var(--mono); font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 500; margin-bottom: 6px; }
.deriv-value { font-family: var(--mono); font-size: 16px; font-weight: 600; font-variant-numeric: tabular-nums; letter-spacing: -0.02em; margin-bottom: 4px; color: var(--ink-1); }
.deriv-value.bull { color: var(--bull); }
.deriv-value.bear { color: var(--bear); }
.deriv-value.neutral { color: var(--warn); }
.deriv-note { font-size: 11px; color: var(--ink-2); line-height: 1.4; }

.ext-links { display: flex; gap: 0; background: var(--bg-1); border-top: 1px solid var(--line); overflow-x: auto; }
.ext-links a { padding: 12px 16px; font-family: var(--mono); font-size: 10px; color: var(--ink-2); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 500; white-space: nowrap; transition: all 0.15s; display: flex; align-items: center; gap: 6px; border-right: 1px solid var(--line); }
.ext-links a:last-child { border-right: none; }
.ext-links a:hover { color: var(--ink-0); background: var(--bg-2); }
.ext-links a svg { width: 11px; height: 11px; opacity: 0.5; }

.signal-controls { display: flex; align-items: center; gap: 12px; padding: 12px 24px; border-bottom: 1px solid var(--line); background: var(--bg-1); flex-wrap: wrap; }
.signal-controls label { display: flex; align-items: center; gap: 6px; font-family: var(--mono); font-size: 11px; color: var(--ink-2); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 500; cursor: pointer; }
.signal-controls input[type=checkbox] { accent-color: var(--accent); cursor: pointer; }
.signal-controls select { background: var(--bg-2); border: 1px solid var(--line-2); color: var(--ink-1); padding: 5px 9px; border-radius: 5px; font-family: var(--mono); font-size: 11px; cursor: pointer; }
.btn-clear, .btn-export, .btn-import { background: transparent; border: 1px solid var(--line-2); color: var(--ink-2); padding: 5px 12px; border-radius: 5px; font-family: var(--mono); font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; transition: all 0.15s; }
.btn-export:hover { color: var(--accent); border-color: var(--accent); }
.btn-import:hover { color: var(--accent); border-color: var(--accent); }
.btn-clear:hover { color: var(--bear); border-color: var(--bear); }
.btn-clear { margin-left: auto; }

.stats-strip { display: grid; grid-template-columns: repeat(4, 1fr); background: var(--line); gap: 1px; border-bottom: 1px solid var(--line); }
.stat-cell { background: var(--bg-0); padding: 14px 20px; }
.stat-label { font-family: var(--mono); font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 500; margin-bottom: 3px; }
.stat-value { font-family: var(--mono); font-size: 20px; font-weight: 600; font-variant-numeric: tabular-nums; letter-spacing: -0.02em; }
.stat-value.up { color: var(--bull); }
.stat-value.down { color: var(--bear); }

.watching { padding: 12px 24px; background: var(--bg-1); border-bottom: 1px solid var(--line); }
.watching-head { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 8px; }
.watching-head .label { font-family: var(--mono); font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.12em; font-weight: 500; }
.watching-head .count { font-family: var(--mono); font-size: 10px; color: var(--ink-2); }
.watching-list { display: flex; flex-direction: column; gap: 5px; max-height: 160px; overflow-y: auto; }
.watching-item { display: flex; justify-content: space-between; align-items: center; font-family: var(--mono); font-size: 11px; padding: 7px 11px; background: var(--bg-2); border-radius: 5px; border: 1px solid var(--line); gap: 10px; }
.watching-item-left { display: flex; align-items: center; gap: 8px; color: var(--ink-2); flex: 1; min-width: 0; overflow: hidden; }
.watching-item-left .text { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.pair-tag { font-size: 10px; padding: 2px 7px; border-radius: 4px; background: var(--bg-4); color: var(--ink-1); text-transform: uppercase; letter-spacing: 0.04em; font-weight: 700; flex-shrink: 0; }
.pair-tag.long { background: var(--bull-bg); color: var(--bull); }
.pair-tag.short { background: var(--bear-bg); color: var(--bear); }
.tf-tag { font-size: 10px; padding: 2px 6px; border-radius: 4px; background: var(--bg-3); color: var(--ink-2); text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600; flex-shrink: 0; }
.watching-item .distance { color: var(--ink-3); font-size: 10px; white-space: nowrap; }
.watching-empty { font-family: var(--mono); font-size: 11px; color: var(--ink-3); text-align: center; padding: 16px; }

.signals-list { flex: 1; overflow-y: auto; max-height: calc(100vh - 480px); }
.signal-card { padding: 18px 24px; border-bottom: 1px solid var(--line); display: flex; flex-direction: column; gap: 12px; transition: background 0.15s; position: relative; }
.signal-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--ink-4); }
.signal-card.long::before { background: var(--bull); }
.signal-card.short::before { background: var(--bear); }
.signal-card:hover { background: var(--bg-1); }
.signal-row1 { display: flex; justify-content: space-between; align-items: center; gap: 10px; flex-wrap: wrap; }
.signal-row1-left { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.signal-pair { font-family: var(--mono); font-size: 14px; font-weight: 700; color: var(--ink-0); letter-spacing: -0.01em; }
.signal-side { font-family: var(--mono); font-size: 11px; font-weight: 700; padding: 4px 9px; border-radius: 5px; text-transform: uppercase; letter-spacing: 0.08em; }
.signal-side.long { background: var(--bull-bg); color: var(--bull); }
.signal-side.short { background: var(--bear-bg); color: var(--bear); }
.signal-strat { font-family: var(--mono); font-size: 11px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 500; }
.signal-score-badge { font-family: var(--mono); font-size: 10px; font-weight: 700; padding: 3px 7px; border-radius: 4px; background: var(--accent-bg); color: var(--accent); }
.signal-status { font-family: var(--mono); font-size: 10px; font-weight: 600; padding: 4px 9px; border-radius: 5px; text-transform: uppercase; letter-spacing: 0.08em; }
.signal-status.active { background: var(--warn-bg); color: var(--warn); }
.signal-status.tp { background: var(--bull-bg); color: var(--bull); }
.signal-status.sl { background: var(--bear-bg); color: var(--bear); }
.signal-status.timeout { background: var(--bg-3); color: var(--ink-3); }
.signal-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; font-family: var(--mono); }
.signal-cell label { display: block; font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 500; margin-bottom: 4px; }
.signal-cell value { display: block; font-size: 13px; font-weight: 600; color: var(--ink-1); font-variant-numeric: tabular-nums; letter-spacing: -0.01em; }
.signal-cell value.entry { color: var(--accent); }
.signal-cell value.stop { color: var(--bear); }
.signal-cell value.target { color: var(--bull); }
.signal-cell value.up { color: var(--bull); }
.signal-cell value.down { color: var(--bear); }
.signal-progress { display: flex; align-items: center; gap: 10px; font-family: var(--mono); font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; }
.progress-track { flex: 1; height: 4px; background: var(--bg-3); border-radius: 2px; position: relative; overflow: hidden; }
.progress-fill { position: absolute; top: 0; left: 0; height: 100%; transition: width 0.3s, background 0.3s; }
.progress-fill.bull { background: var(--bull); box-shadow: 0 0 8px var(--bull-glow); }
.progress-fill.bear { background: var(--bear); box-shadow: 0 0 8px var(--bear-glow); }
.signal-meta { display: flex; justify-content: space-between; align-items: center; font-family: var(--mono); font-size: 11px; color: var(--ink-3); gap: 12px; flex-wrap: wrap; }
.signal-meta .reason { color: var(--ink-2); font-style: italic; flex: 1; min-width: 180px; }
.signal-meta a { color: var(--accent); font-style: normal; }
.signal-meta a:hover { text-decoration: underline; }

.signal-empty { padding: 60px 24px; text-align: center; }
.signal-empty-icon { width: 48px; height: 48px; margin: 0 auto 16px; border: 1px dashed var(--line-2); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.signal-empty-icon svg { width: 20px; height: 20px; color: var(--ink-3); }
.signal-empty h4 { font-size: 15px; color: var(--ink-1); margin-bottom: 8px; font-weight: 600; letter-spacing: -0.02em; }
.signal-empty p { font-size: 12px; color: var(--ink-3); max-width: 380px; margin: 0 auto; line-height: 1.5; }

/* PERFORMANCE TAB */
.perf-wrap { padding: 28px; max-width: 1400px; margin: 0 auto; }
.perf-hero { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1px; background: var(--line); border-radius: 12px; overflow: hidden; margin-bottom: 32px; border: 1px solid var(--line); }
.perf-hero-cell { background: var(--bg-1); padding: 24px; }
.perf-hero-label { font-family: var(--mono); font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px; }
.perf-hero-value { font-family: var(--mono); font-size: 32px; font-weight: 600; font-variant-numeric: tabular-nums; letter-spacing: -0.03em; color: var(--ink-0); }
.perf-hero-value.up { color: var(--bull); }
.perf-hero-value.down { color: var(--bear); }
.perf-hero-value.warn { color: var(--warn); }
.perf-hero-note { font-size: 12px; color: var(--ink-2); margin-top: 6px; }
.perf-section { margin-bottom: 36px; }
.perf-section-title { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ink-2); margin-bottom: 14px; display: flex; align-items: center; gap: 10px; }
.perf-section-title .help { font-family: var(--mono); font-size: 10px; color: var(--ink-3); text-transform: none; letter-spacing: 0; font-weight: 400; }
.perf-table { width: 100%; border-collapse: collapse; background: var(--bg-1); border-radius: 8px; overflow: hidden; border: 1px solid var(--line); }
.perf-table th, .perf-table td { padding: 12px 16px; text-align: left; font-family: var(--mono); font-size: 12px; font-variant-numeric: tabular-nums; border-bottom: 1px solid var(--line); }
.perf-table th { font-size: 10px; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 500; background: var(--bg-2); }
.perf-table tr:last-child td { border-bottom: none; }
.perf-table td.bull-cell { color: var(--bull); font-weight: 600; }
.perf-table td.bear-cell { color: var(--bear); font-weight: 600; }
.perf-table td.muted { color: var(--ink-3); }
.perf-table .wr-bar { width: 80px; height: 4px; background: var(--bg-3); border-radius: 2px; overflow: hidden; display: inline-block; vertical-align: middle; margin-left: 8px; }
.perf-table .wr-bar-fill { height: 100%; transition: width 0.4s; }
.perf-table .wr-bar-fill.up { background: var(--bull); }
.perf-table .wr-bar-fill.down { background: var(--bear); }
.perf-table .wr-bar-fill.warn { background: var(--warn); }
.perf-table tr.disabled { opacity: 0.6; }
