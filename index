  document.getElementById('verdictWord').textContent = word;
  document.getElementById('heroVerdict').className = 'hero-verdict ' + cls;
  document.getElementById('verdictScore').textContent = (final >= 0 ? '+' : '') + final.toFixed(0);
  const tot = bullCount + bearCount + neutCount;
  const dom = Math.max(bullCount, bearCount, neutCount);
  const agree = tot ? Math.round(dom / tot * 100) : 0;
  document.getElementById('verdictAgree').textContent = agree + '%';
