<script>
// ============================================================
// STATE
// ============================================================
const STATE_KEY = 'sawaiz_signals_state_v5';
const FILTER_KEY = 'sawaiz_disabled_configs_v5';
const MIGRATION_KEY = 'sawaiz_v4_migration_done';
const state = {
  signals: [], lastScanAt: 0, livePrice: null, ticker: null,
  watching: [], pairPrices: {}, disabledConfigs: new Set(),
  pairTrends: {} // pair -> { direction: 'up'/'down'/'flat', strength: 0-2 } from 1h EMA50
};

// Check for v4 data
const v4Data = localStorage.getItem('sawaiz_signals_state_v4');
const migrationDone = localStorage.getItem(MIGRATION_KEY);
if (v4Data && !migrationDone) {
  document.getElementById('migrationBanner').style.display = 'flex';
}
document.getElementById('archiveOldBtn').addEventListener('click', () => {
  // Archive: store under separate key, start fresh
  try {
    const old = localStorage.getItem('sawaiz_signals_state_v4');
    if (old) localStorage.setItem('sawaiz_archive_v4', old);
  } catch (e) {}
  localStorage.setItem(MIGRATION_KEY, 'archived');
  document.getElementById('migrationBanner').style.display = 'none';
  state.signals = []; persist(); renderSignals();
});
document.getElementById('keepOldBtn').addEventListener('click', () => {
  // Migrate v4 signals into v5 (will look bad, but user choice)
  try {
    const old = JSON.parse(v4Data || '{}');
    if (old.signals) state.signals = old.signals;
    persist();
  } catch (e) {}
  localStorage.setItem(MIGRATION_KEY, 'kept');
  document.getElementById('migrationBanner').style.display = 'none';
  renderSignals();
});

try {
  const saved = JSON.parse(localStorage.getItem(STATE_KEY) || '{}');
  if (saved.signals) state.signals = saved.signals;
} catch (e) {}
try {
  const saved = JSON.parse(localStorage.getItem(FILTER_KEY) || '[]');
  state.disabledConfigs = new Set(saved);
} catch (e) {}
function persist() { try { localStorage.setItem(STATE_KEY, JSON.stringify({ signals: state.signals })); } catch (e) {} }
function persistFilters() { try { localStorage.setItem(FILTER_KEY, JSON.stringify([...state.disabledConfigs])); } catch (e) {} }

const PAIRS = ['BTCUSDT', 'ETHUSDT', 'SOLUSDT', 'BNBUSDT', 'XRPUSDT', 'DOGEUSDT', 'ADAUSDT', 'AVAXUSDT'];
const TIMEFRAMES = [
  { bin: '5m',  label: '5m',  weight: 0.5  },
  { bin: '15m', label: '15m', weight: 0.75 },
  { bin: '30m', label: '30m', weight: 1.0  },
  { bin: '1h',  label: '1h',  weight: 1.25 },
  { bin: '4h',  label: '4h',  weight: 1.75 },
  { bin: '1d',  label: '1d',  weight: 2.0  }
];
// v5: removed 5m signals — too noisy. Focus on 15m/30m/1h with strict filters.
const SIGNAL_TFS = ['15m', '30m', '1h'];

// ============================================================
// TABS
// ============================================================
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('panel-' + btn.dataset.tab).classList.add('active');
    if (btn.dataset.tab === 'performance') renderPerformance();
  });
});

// ============================================================
// WEBSOCKET
// ============================================================
let ws = null, wsRetry = 0;
function connectWS() {
  setWsStatus('connecting', 'WS');
  try {
    const streams = PAIRS.map(p => p.toLowerCase() + '@aggTrade').join('/');
    ws = new WebSocket(`wss://fstream.binance.com/stream?streams=${streams}`);
    ws.onopen = () => { wsRetry = 0; setWsStatus('live', 'LIVE'); };
    ws.onmessage = (msg) => {
      try {
        const d = JSON.parse(msg.data);
        if (!d.data) return;
        const pair = d.data.s;
        const price = +d.data.p;
        state.pairPrices[pair] = price;
        if (pair === 'BTCUSDT') updateBtcPrice(price);
        evaluateLive(pair, price);
      } catch (e) {}
    };
    ws.onerror = () => setWsStatus('off', 'ERR');
    ws.onclose = () => { setWsStatus('off', 'OFF'); wsRetry++; setTimeout(connectWS, Math.min(30000, 1000 * Math.pow(2, wsRetry))); };
  } catch (e) { setTimeout(connectWS, 5000); }
}
function setWsStatus(cls, txt) {
  document.getElementById('wsDot').className = 'live-dot ' + cls;
  document.getElementById('wsText').textContent = txt;
}
function updateBtcPrice(p) {
  const prev = state.livePrice;
  state.livePrice = p;
  const el = document.getElementById('livePrice');
  el.textContent = '$' + p.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  if (prev != null) {
    el.classList.remove('up', 'down');
    if (p > prev) { el.classList.add('up'); setTimeout(() => el.classList.remove('up'), 400); }
    else if (p < prev) { el.classList.add('down'); setTimeout(() => el.classList.remove('down'), 400); }
  }
  if (state.ticker) {
    const open = +state.ticker.openPrice;
    if (open) {
      const pct = ((p / open) - 1) * 100;
      const pill = document.getElementById('liveDelta');
      pill.className = 'delta-pill ' + (pct >= 0 ? 'up' : 'down');
      pill.textContent = (pct >= 0 ? '+' : '') + pct.toFixed(2) + '%';
    }
  }
}
function evaluateLive(pair, price) {
  let changed = false;
  const now = Date.now();
  const tfMs = { '15m':900000, '30m':1800000, '1h':3600000 };
  const TIMEOUT_BARS = 20;
  for (const s of state.signals) {
    if (s.pair !== pair) continue;
    if (s.status !== 'active') continue;
    s.lastPrice = price;
    if (s.side === 'long') {
      if (price <= s.stop) { closeSignal(s, 'sl', s.stop); changed = true; continue; }
      if (price >= s.target) { closeSignal(s, 'tp', s.target); changed = true; continue; }
    } else {
      if (price >= s.stop) { closeSignal(s, 'sl', s.stop); changed = true; continue; }
      if (price <= s.target) { closeSignal(s, 'tp', s.target); changed = true; continue; }
    }
    const elapsed = now - s.createdAt;
    const limit = (tfMs[s.tf] || 900000) * TIMEOUT_BARS;
    if (elapsed > limit) { closeSignal(s, 'timeout', price); changed = true; }
  }
  if (changed) { persist(); renderSignals(); }
  else updateActiveProgress();
}

// ============================================================
// REST
// ============================================================
async function tryFetch(url) {
  const r = await fetch(url);
  if (!r.ok) throw new Error('HTTP ' + r.status);
  return r.json();
}
async function fetchBtcTicker() {
  try { state.ticker = await tryFetch('https://fapi.binance.com/fapi/v1/ticker/24hr?symbol=BTCUSDT'); }
  catch (e) {
    const j = await tryFetch('https://api.bybit.com/v5/market/tickers?category=linear&symbol=BTCUSDT');
    const t = j.result.list[0];
    state.ticker = { lastPrice: t.lastPrice, openPrice: t.prevPrice24h, priceChangePercent: (+t.price24hPcnt * 100).toFixed(2), highPrice: t.highPrice24h, lowPrice: t.lowPrice24h, quoteVolume: t.turnover24h };
  }
  renderTickerStrip();
  if (state.livePrice == null && state.ticker.lastPrice) updateBtcPrice(+state.ticker.lastPrice);
}
function renderTickerStrip() {
  if (!state.ticker) return;
  const d = state.ticker;
  const chg = +d.priceChangePercent;
  setText('sub-change', (chg >= 0 ? '+' : '') + chg.toFixed(2) + '%', chg >= 0 ? 'up' : 'down');
  setText('sub-high', '$' + (+d.highPrice).toLocaleString(undefined, { maximumFractionDigits: 0 }));
  setText('sub-low', '$' + (+d.lowPrice).toLocaleString(undefined, { maximumFractionDigits: 0 }));
  setText('sub-vol', fmtUSD(+d.quoteVolume));
}
function setText(id, txt, cls) {
  const el = document.getElementById(id);
  el.textContent = txt;
  el.classList.remove('up', 'down', 'warn');
  if (cls) el.classList.add(cls);
}
function fmtUSD(n) {
  if (n >= 1e9) return '$' + (n / 1e9).toFixed(2) + 'B';
  if (n >= 1e6) return '$' + (n / 1e6).toFixed(2) + 'M';
  if (n >= 1e3) return '$' + (n / 1e3).toFixed(1) + 'K';
  return '$' + n.toFixed(2);
}
async function fetchKlines(symbol, interval, limit = 120) {
  try {
    const arr = await tryFetch(`https://fapi.binance.com/fapi/v1/klines?symbol=${symbol}&interval=${interval}&limit=${limit}`);
    return arr.map(k => ({ t: k[0], o: +k[1], h: +k[2], l: +k[3], c: +k[4], v: +k[5] }));
  } catch (e) {
    const ivMap = { '5m': '5', '15m': '15', '30m': '30', '1h': '60', '4h': '240', '1d': 'D' };
    const j = await tryFetch(`https://api.bybit.com/v5/market/kline?category=linear&symbol=${symbol}&interval=${ivMap[interval]}&limit=${limit}`);
    return j.result.list.slice().reverse().map(k => ({ t: +k[0], o: +k[1], h: +k[2], l: +k[3], c: +k[4], v: +k[5] }));
  }
}
async function fetchDerivatives() {
  let funding = null, oi = null, ls = null;
  try {
    const f = await tryFetch('https://fapi.binance.com/fapi/v1/premiumIndex?symbol=BTCUSDT');
    funding = +f.lastFundingRate * 100;
    setText('sub-fund', (funding >= 0 ? '+' : '') + funding.toFixed(4) + '%', Math.abs(funding) > 0.02 ? (funding > 0 ? 'down' : 'up') : 'warn');
  } catch (e) {}
  try {
    const arr = await tryFetch('https://fapi.binance.com/futures/data/openInterestHist?symbol=BTCUSDT&period=1h&limit=24');
    if (arr.length) { const first = +arr[0].sumOpenInterest; const last = +arr[arr.length - 1].sumOpenInterest; oi = ((last - first) / first) * 100; }
  } catch (e) {}
  try {
    const arr = await tryFetch('https://fapi.binance.com/futures/data/globalLongShortAccountRatio?symbol=BTCUSDT&period=1h&limit=1');
    if (arr.length) ls = { ratio: +arr[0].longShortRatio, longPct: +arr[0].longAccount * 100, shortPct: +arr[0].shortAccount * 100 };
  } catch (e) {}
  return { funding, oi, ls };
}

// ============================================================
// INDICATORS
// ============================================================
function sma(arr, len) { if (arr.length < len) return null; let s=0; for (let i=arr.length-len;i<arr.length;i++) s+=arr[i]; return s/len; }
function ema(closes, len) { if (closes.length < len) return null; const k=2/(len+1); let e=closes.slice(0,len).reduce((a,b)=>a+b,0)/len; for (let i=len;i<closes.length;i++) e=closes[i]*k+e*(1-k); return e; }
function emaSeries(closes, len) {
  if (closes.length < len) return [];
  const k=2/(len+1);
  const out = new Array(closes.length).fill(null);
  let e = closes.slice(0, len).reduce((a,b)=>a+b,0) / len;
  out[len-1] = e;
  for (let i = len; i < closes.length; i++) {
    e = closes[i] * k + e * (1 - k);
    out[i] = e;
  }
  return out;
}
function rsi(closes, len = 14) {
  if (closes.length < len + 1) return null;
  let g=0, l=0;
  for (let i=1;i<=len;i++) { const d=closes[i]-closes[i-1]; if (d>0) g+=d; else l-=d; }
  g/=len; l/=len;
  for (let i=len+1;i<closes.length;i++) { const d=closes[i]-closes[i-1]; g=(g*(len-1)+(d>0?d:0))/len; l=(l*(len-1)+(d<0?-d:0))/len; }
  return 100-100/(1+g/(l||1e-10));
}
function atr(candles, len=14) {
  const trs = candles.map((c,i) => { if (i===0) return c.h-c.l; const p=candles[i-1]; return Math.max(c.h-c.l, Math.abs(c.h-p.c), Math.abs(c.l-p.c)); });
  if (trs.length < len) return null;
  let s=0; for (let i=trs.length-len;i<trs.length;i++) s+=trs[i]; return s/len;
}

// VOLUME PROFILE — POC, VAH, VAL
function volumeProfile(candles, bins = 40) {
  // Build a histogram of volume traded at each price bin over the last N candles
  if (candles.length < 20) return null;
  let minP = Infinity, maxP = -Infinity;
  for (const c of candles) { if (c.l < minP) minP = c.l; if (c.h > maxP) maxP = c.h; }
  if (maxP <= minP) return null;
  const binSize = (maxP - minP) / bins;
  const profile = new Array(bins).fill(0);
  for (const c of candles) {
    // Distribute candle volume across bins it spans
    const lowBin = Math.max(0, Math.floor((c.l - minP) / binSize));
    const highBin = Math.min(bins - 1, Math.floor((c.h - minP) / binSize));
    const spread = highBin - lowBin + 1;
    const volPerBin = c.v / spread;
    for (let i = lowBin; i <= highBin; i++) profile[i] += volPerBin;
  }
  // POC = highest volume bin
  let pocIdx = 0;
  for (let i = 1; i < bins; i++) if (profile[i] > profile[pocIdx]) pocIdx = i;
  const totalVol = profile.reduce((a, b) => a + b, 0);
  const targetVol = totalVol * 0.70; // value area = 70% of volume
  // Expand outward from POC until we capture 70%
  let cumVol = profile[pocIdx];
  let low = pocIdx, high = pocIdx;
  while (cumVol < targetVol && (low > 0 || high < bins - 1)) {
    const lowVol = low > 0 ? profile[low - 1] : -1;
    const highVol = high < bins - 1 ? profile[high + 1] : -1;
    if (lowVol >= highVol) { low--; cumVol += profile[low]; }
    else { high++; cumVol += profile[high]; }
  }
  return {
    poc: minP + (pocIdx + 0.5) * binSize,
    vah: minP + (high + 1) * binSize,
    val: minP + low * binSize,
    minP, maxP
  };
}

