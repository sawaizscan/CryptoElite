function computePairTrend(candles1h) {
  // Use 1h EMA50 slope to determine pair trend (THE key fix)
  if (candles1h.length < 60) return { direction: 'flat', strength: 0 };
  const closes = candles1h.map(c => c.c);
  const e50 = emaSeries(closes, 50);
  const cur = e50[e50.length - 1];
  const past = e50[e50.length - 8]; // 8 candles ago = ~8 hours back
  if (cur == null || past == null) return { direction: 'flat', strength: 0 };
  const slope = (cur - past) / past * 100;
  const price = closes[closes.length - 1];
  const aboveEma = price > cur;
  // Strong trend: slope > 0.5% AND price aligned with slope
  if (slope > 0.8 && aboveEma) return { direction: 'up', strength: 2 };
  if (slope > 0.3 && aboveEma) return { direction: 'up', strength: 1 };
  if (slope < -0.8 && !aboveEma) return { direction: 'down', strength: 2 };
  if (slope < -0.3 && !aboveEma) return { direction: 'down', strength: 1 };
  return { direction: 'flat', strength: 0 };
}

function generateSignals(pair, tf, analysis, htfTrend) {
  const out = [];
  if (!analysis || analysis.candles.length < 30) return out;
  const c = analysis.candles[analysis.candles.length - 1];
  const prev = analysis.candles[analysis.candles.length - 2];
  const atrVal = analysis.atr;
  if (!atrVal) return out;
  const closes = analysis.candles.map(x => x.c);
  const vols = analysis.candles.map(x => x.v);
  const avgV = sma(vols.slice(0, -1), 20);
  const volMult = avgV ? c.v / avgV : 1;

  // Volume profile on last 96 candles
  const vp = volumeProfile(analysis.candles.slice(-96));
  if (!vp) return out;

  // ========================================================
  // STRATEGY 1: VP REVERSAL — bounce from VAL with trend (long) or rejection at VAH against retail (short with trend)
  // ========================================================
  // LONG: HTF trending up, price tagged VAL or below, closing back above VAL, with volume
  if (htfTrend.direction === 'up' && c.l <= vp.val * 1.001 && c.c > vp.val && c.c > c.o && volMult > 1.1) {
    let score = 50;
    score += htfTrend.strength * 10;             // +10 to +20
    score += Math.min(20, (volMult - 1) * 20);    // +2 to +20
    if (c.c > prev.h) score += 8;                 // bullish engulf-ish
    if (analysis.rsi != null && analysis.rsi < 45) score += 8; // oversold within uptrend
    if (score >= 70) {
      const stop = vp.val - atrVal * 0.5;
      const target = vp.poc;
      const risk = c.c - stop;
      if (risk > 0 && (target - c.c) > 0) {
        out.push({
          side: 'long', strategy: 'VP-BOUNCE',
          entry: c.c, stop, target,
          reason: `1h ${htfTrend.direction}trend · tagged VAL (${vp.val.toFixed(2)}) · vol ${volMult.toFixed(1)}× · target POC`,
          score: Math.min(100, score)
        });
      }
    }
  }
  // SHORT: HTF down, price tagged VAH or above, closing back below, with volume
  if (htfTrend.direction === 'down' && c.h >= vp.vah * 0.999 && c.c < vp.vah && c.c < c.o && volMult > 1.1) {
    let score = 50;
    score += htfTrend.strength * 10;
    score += Math.min(20, (volMult - 1) * 20);
    if (c.c < prev.l) score += 8;
    if (analysis.rsi != null && analysis.rsi > 55) score += 8;
    if (score >= 70) {
      const stop = vp.vah + atrVal * 0.5;
      const target = vp.poc;
      const risk = stop - c.c;
      if (risk > 0 && (c.c - target) > 0) {
        out.push({
          side: 'short', strategy: 'VP-REJECT',
          entry: c.c, stop, target,
          reason: `1h ${htfTrend.direction}trend · rejected VAH (${vp.vah.toFixed(2)}) · vol ${volMult.toFixed(1)}× · target POC`,
          score: Math.min(100, score)
        });
      }
    }
  }

  // ========================================================
  // STRATEGY 2: BREAKOUT-RETEST — break and retest 20-bar level WITH trend alignment
  // ========================================================
  // Find recent breakout: was the 20-bar high broken in the last 3-8 candles?
  if (htfTrend.direction === 'up' && analysis.candles.length >= 30) {
    const window = analysis.candles.slice(-30, -3);
    const olderHigh = Math.max(...window.slice(0, 20).map(x => x.h));
    // Did any of bars [-8 to -3] break above olderHigh?
    let brokeBar = -1;
    for (let i = analysis.candles.length - 8; i < analysis.candles.length - 2; i++) {
      if (analysis.candles[i].c > olderHigh) { brokeBar = i; break; }
    }
    if (brokeBar > 0) {
      // Now we're looking for a retest: current candle's low touched olderHigh, but close is back above
      if (c.l <= olderHigh * 1.003 && c.l >= olderHigh * 0.996 && c.c > olderHigh && c.c > c.o && volMult > 1.0) {
        let score = 55 + htfTrend.strength * 12 + Math.min(15, (volMult - 1) * 18);
        if (score >= 70) {
          const stop = c.l - atrVal * 0.3;
          const target = c.c + (c.c - stop) * 1.8;
          out.push({
            side: 'long', strategy: 'BREAKOUT-RETEST',
            entry: c.c, stop, target,
            reason: `Broke ${olderHigh.toFixed(2)} ${analysis.candles.length - brokeBar} bars ago · clean retest · 1h up`,
            score: Math.min(100, score)
          });
        }
      }
    }
  }
  if (htfTrend.direction === 'down' && analysis.candles.length >= 30) {
    const window = analysis.candles.slice(-30, -3);
    const olderLow = Math.min(...window.slice(0, 20).map(x => x.l));
    let brokeBar = -1;
    for (let i = analysis.candles.length - 8; i < analysis.candles.length - 2; i++) {
      if (analysis.candles[i].c < olderLow) { brokeBar = i; break; }
    }
    if (brokeBar > 0) {
      if (c.h >= olderLow * 0.997 && c.h <= olderLow * 1.004 && c.c < olderLow && c.c < c.o && volMult > 1.0) {
        let score = 55 + htfTrend.strength * 12 + Math.min(15, (volMult - 1) * 18);
        if (score >= 70) {
          const stop = c.h + atrVal * 0.3;
          const target = c.c - (stop - c.c) * 1.8;
          out.push({
            side: 'short', strategy: 'BREAKDOWN-RETEST',
            entry: c.c, stop, target,
            reason: `Broke ${olderLow.toFixed(2)} ${analysis.candles.length - brokeBar} bars ago · clean retest · 1h down`,
            score: Math.min(100, score)
          });
        }
      }
    }
  }

  return out;
}

function generateWatching(pair, tf, analysis, htfTrend) {
  if (!analysis || analysis.candles.length < 30) return [];
  const c = analysis.candles[analysis.candles.length - 1];
  const out = [];
  const vp = volumeProfile(analysis.candles.slice(-96));
  if (!vp) return out;

  // Approaching VAL with up-trend
  if (htfTrend.direction === 'up') {
    const distVal = ((c.c - vp.val) / c.c * 100);
    if (distVal > 0 && distVal < 0.8) {
      out.push({ pair, tf, side: 'long', text: `Approaching VAL ($${vp.val.toFixed(2)})`, distance: `${distVal.toFixed(2)}% · 1h up`, urgency: 2 - distVal });
    }
  }
  if (htfTrend.direction === 'down') {
    const distVah = ((vp.vah - c.c) / c.c * 100);
    if (distVah > 0 && distVah < 0.8) {
      out.push({ pair, tf, side: 'short', text: `Approaching VAH ($${vp.vah.toFixed(2)})`, distance: `${distVah.toFixed(2)}% · 1h down`, urgency: 2 - distVah });
    }
  }
  return out;
}

function uid() { return Date.now().toString(36) + Math.random().toString(36).slice(2, 7); }
function configKey(pair, strategy, tf) { return `${pair}:${strategy}:${tf}`; }

function addSignal(pair, tf, sig) {
  const tfMs = { '15m':900000, '30m':1800000, '1h':3600000 }[tf];
  const cutoff = Date.now() - tfMs * 8;
  if (state.signals.some(s => s.pair === pair && s.tf === tf && s.side === sig.side && s.strategy === sig.strategy && s.createdAt > cutoff)) return false;
  if (state.disabledConfigs.has(configKey(pair, sig.strategy, tf))) return false;
  state.signals.unshift({
    id: uid(), pair, side: sig.side, strategy: sig.strategy, tf,
    entry: sig.entry, stop: sig.stop, target: sig.target, reason: sig.reason,
    score: sig.score,
    status: 'active', createdAt: Date.now(), updatedAt: Date.now(),
    closedAt: null, closePrice: null, pnlR: null,
    lastPrice: sig.entry,
    version: 'v5'
  });
  if (state.signals.length > 1000) state.signals = state.signals.slice(0, 1000);
  persist();
  return true;
}

function closeSignal(s, outcome, price) {
  s.status = outcome; s.closedAt = Date.now(); s.closePrice = price;
  const risk = Math.abs(s.entry - s.stop);
  const move = s.side === 'long' ? (price - s.entry) : (s.entry - price);
  s.pnlR = risk > 0 ? move / risk : 0;
}

function updateActiveProgress() {
  document.querySelectorAll('.signal-card[data-status="active"]').forEach(card => {
    const id = card.dataset.id;
    const s = state.signals.find(x => x.id === id);
    if (!s) return;
    const price = state.pairPrices[s.pair] || s.lastPrice;
    const fill = card.querySelector('.progress-fill');
    const pnlVal = card.querySelector('.live-pnl');
    if (fill) {
      const totalRange = Math.abs(s.target - s.stop);
      const fromStop = s.side === 'long' ? (price - s.stop) : (s.stop - price);
      const pct = Math.max(0, Math.min(100, (fromStop / totalRange) * 100));
      fill.style.width = pct + '%';
      fill.className = 'progress-fill ' + (pct > 50 ? 'bull' : 'bear');
    }
    if (pnlVal) {
      const risk = Math.abs(s.entry - s.stop);
      const move = s.side === 'long' ? (price - s.entry) : (s.entry - price);
      const r = risk > 0 ? move / risk : 0;
      pnlVal.textContent = (r >= 0 ? '+' : '') + r.toFixed(2) + 'R';
      pnlVal.style.color = r >= 0 ? 'var(--bull)' : 'var(--bear)';
    }
  });
}

